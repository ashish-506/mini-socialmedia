<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 text-white min-h-screen overflow-hidden">
    <div class="flex w-full h-screen">
        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-y-auto">
            <!-- Header -->
            <div class="border-b border-zinc-800 p-6 flex justify-between items-center">
                <div>
                    <h1 class="text-3xl font-bold">Hello, <%= user.name %></h1>
                    <p class="text-zinc-400 mt-1">@<%= user.username %></p>
                </div>
                <a class="border border-red-500 text-red-500 hover:bg-red-500 hover:text-white transition-colors rounded-md px-4 py-2 text-sm font-medium" href="/logout">Logout</a>
            </div>

            <!-- Content Area -->
            <div class="flex-1 p-10 overflow-y-auto">
                <!-- Create Post Section -->
                <div class="mb-12">
                    <h3 class="text-xl font-semibold mb-4">Share Your Thoughts</h3>
                    <form action="/post" method="post" class="space-y-4">
                        <textarea
                            required
                            placeholder="What's on your mind?"
                            rows="4"
                            class="w-full px-4 py-3 outline-none bg-transparent border border-zinc-700 rounded-md focus:border-blue-500 transition-colors placeholder-zinc-500 resize-vertical"
                            name="content"
                        ></textarea>
                        <div class="flex justify-start">
                            <input
                                type="submit"
                                value="Create New Post"
                                class="bg-blue-500 hover:bg-blue-600 transition-colors px-6 py-2 rounded-md font-medium cursor-pointer"
                            >
                        </div>
                    </form>
                </div>

                <!-- Your Posts Section -->
                <div>
                    <h3 class="text-xl font-semibold mb-6">Your Posts</h3>
                    <% if(user.posts && user.posts.length > 0) { %>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <% user.posts.slice().reverse().forEach((post) => { %>
                            <div class="border border-zinc-800 rounded-lg p-6 hover:border-zinc-700 transition-colors">
                                <h4 class="text-blue-400 font-semibold mb-3">@<%= user.username %></h4>
                                <p class="text-zinc-300 text-sm leading-relaxed mb-4 line-clamp-4"><%= post.content %></p>
                                <div class="flex items-center justify-between text-xs text-zinc-500 border-t border-zinc-800 pt-4">
                                    <span><%= post.likes.length %> <%= post.likes.length === 1 ? 'Like' : 'Likes' %></span>
                                    <div class="flex gap-4">
                                        <a class="text-blue-400 hover:text-blue-300 transition-colors" href="/like/<%= post._id %>">
                                            <%= post.likes.includes(user._id) ? "Unlike" : "Like" %>
                                        </a>
                                        <a class="text-blue-400 hover:text-blue-300 transition-colors" href="/edit/<%= post._id %>">Edit</a>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="border border-zinc-800 rounded-lg p-8 text-center">
                            <p class="text-zinc-500">No posts yet. Create your first post above!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="w-80 border-l border-zinc-800 p-6 overflow-y-auto">
            <h3 class="text-xl font-semibold mb-6 border-b border-zinc-800 pb-2">Other Users</h3>
            <div class="flex flex-col gap-4">
                <% if(allUsers && allUsers.length > 0) { %>
                    <% allUsers.forEach((val) => { %>
                        <% if(String(user._id) !== String(val._id)) { %>
                            <a href="/user/<%= val._id %>" class="text-blue-500 hover:text-blue-700">
                                <p class="text-blue-400 font-medium text-sm"><%= val.username %></p>
                                <p class="text-xs text-zinc-500 mt-1"><%= val.name %></p>
                            </a>
                        <% } %>
                    <% }) %>
                <% } else { %>
                    <p class="text-sm text-zinc-500">No other users</p>
                <% } %>
            </div>
        </div>

    </div>
</body>
</html>