<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 text-white min-h-screen">
    <!-- Header -->
    <div class="w-full flex justify-end p-6">
        <a class="bg-red-500 hover:bg-red-600 transition-colors rounded-md px-4 py-2 text-sm font-medium inline-block" href="/logout">Logout</a>
    </div>

    <!-- Main Content -->
    <div class="flex items-center justify-center min-h-[calc(100vh-120px)] p-6">
        <div class="w-full max-w-2xl">
            <div class="text-center mb-8">
                <h1 class="text-4xl font-bold mb-2">Edit Post</h1>
                <p class="text-zinc-400">Update your thoughts</p>
            </div>

            <div class="bg-zinc-800 rounded-lg p-8 border border-zinc-700">
                <form action="/update/<%= post._id %>" method="post" class="space-y-6">
                    <div>
                        <label for="content" class="block text-sm font-medium text-zinc-300 mb-2">
                            Post Content
                        </label>
                        <textarea
                            id="content"
                            name="content"
                            placeholder="What's on your mind?"
                            rows="6"
                            class="w-full px-4 py-3 outline-none bg-zinc-700 border-2 border-zinc-600 rounded-md focus:border-blue-500 transition-colors placeholder-zinc-400 resize-vertical"
                            required
                        ><%= post.content %></textarea>
                    </div>

                    <div class="flex gap-4 justify-center">
                        <button
                            type="submit"
                            class="bg-yellow-500 hover:bg-yellow-600 transition-colors px-8 py-3 rounded-lg font-medium text-black"
                        >
                            Update Post
                        </button>

                        <a
                            href="/profile"
                            class="bg-zinc-600 hover:bg-zinc-500 transition-colors px-8 py-3 rounded-lg font-medium"
                        >
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>